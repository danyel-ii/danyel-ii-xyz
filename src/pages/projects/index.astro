---
import SiteLayout from '../../layouts/SiteLayout.astro'
import KnowledgeCard from '../../components/cards/KnowledgeCard.astro'
import SectionEyebrow from '../../components/ui/SectionEyebrow.astro'
import { siteMeta } from '../../data/site'
import {
  getCollectionLabel,
  getEntryHref,
  sortProjects,
  getVisibleCollection,
} from '../../lib/content'

const entries = sortProjects(await getVisibleCollection('projects'))
---

<SiteLayout title={`Projects | ${siteMeta.domain}`} description="Projects, tools, and deployed experiments from danyel-ii.xyz." canonical="/projects/">
  <section class="section-shell content-index">
    <div class="section-shell__intro" data-reveal>
      <SectionEyebrow label="DIR.EXE // PROJECT RECORDS" />
      <div class="section-shell__heading">
        <h1>Projects with durable pages instead of only homepage cards.</h1>
        <p>Featured and stable work is sorted first, followed by active and seed-stage records. Each project keeps its own links, stack, and current state.</p>
      </div>
    </div>
    <div class="knowledge-grid">
      {
        entries.map((entry) => (
          <KnowledgeCard
            href={getEntryHref(entry)}
            kind={getCollectionLabel(entry.collection)}
            title={entry.data.title}
            summary={entry.data.summary}
            updated={entry.data.updated}
            status={entry.data.status}
            topics={entry.data.topics}
          />
        ))
      }
    </div>
  </section>
</SiteLayout>
