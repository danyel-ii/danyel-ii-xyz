---
import SiteLayout from '../../layouts/SiteLayout.astro'
import KnowledgeCard from '../../components/cards/KnowledgeCard.astro'
import SectionEyebrow from '../../components/ui/SectionEyebrow.astro'
import { siteMeta } from '../../data/site'
import {
  getCollectionLabel,
  getEntryHref,
  sortByUpdatedDesc,
  getVisibleCollection,
} from '../../lib/content'

const entries = sortByUpdatedDesc(await getVisibleCollection('notes'))
---

<SiteLayout title={`Notes | ${siteMeta.domain}`} description="Evergreen notes and references from danyel-ii.xyz." canonical="/notes/">
  <section class="section-shell content-index">
    <div class="section-shell__intro" data-reveal>
      <SectionEyebrow label="NOTE.REG // REFERENCE LAYER" />
      <div class="section-shell__heading">
        <h1>Evergreen notes and reference material.</h1>
        <p>These entries are sorted by recent revision so the most actively maintained material stays near the top.</p>
      </div>
    </div>
    <div class="knowledge-grid">
      {
        entries.map((entry) => (
          <KnowledgeCard
            href={getEntryHref(entry)}
            kind={getCollectionLabel(entry.collection)}
            title={entry.data.title}
            summary={entry.data.summary}
            updated={entry.data.updated}
            status={entry.data.status}
            topics={entry.data.topics}
          />
        ))
      }
    </div>
  </section>
</SiteLayout>
