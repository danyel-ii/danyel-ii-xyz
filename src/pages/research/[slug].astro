---
import { getCollection, render } from 'astro:content'
import SiteLayout from '../../layouts/SiteLayout.astro'
import ContentDetail from '../../components/content/ContentDetail.astro'
import { siteMeta } from '../../data/site'

export async function getStaticPaths() {
  const entries = await getCollection('research', ({ data }) => !data.draft)
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<SiteLayout
  title={`${entry.data.title} | ${siteMeta.domain}`}
  description={entry.data.summary}
  canonical={`/research/${entry.slug}/`}
>
  <ContentDetail entry={entry} kind="RESEARCH" tags={entry.data.tags}>
    <Content />
  </ContentDetail>
</SiteLayout>
