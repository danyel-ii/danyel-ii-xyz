---
import SiteLayout from '../../layouts/SiteLayout.astro'
import KnowledgeCard from '../../components/cards/KnowledgeCard.astro'
import SectionEyebrow from '../../components/ui/SectionEyebrow.astro'
import { siteMeta } from '../../data/site'
import {
  getCollectionLabel,
  getEntryHref,
  sortByUpdatedDesc,
  getVisibleCollection,
} from '../../lib/content'

const entries = sortByUpdatedDesc(await getVisibleCollection('research'))
---

<SiteLayout title={`Research | ${siteMeta.domain}`} description="Research notes from danyel-ii.xyz." canonical="/research/">
  <section class="section-shell content-index">
    <div class="section-shell__intro" data-reveal>
      <SectionEyebrow label="RES.ARC // ALL NOTES" />
      <div class="section-shell__heading">
        <h1>Research notes and protocol observations.</h1>
        <p>Entries are ordered by recent revision and kept close to the actual learning process.</p>
      </div>
    </div>
    <div class="knowledge-grid">
      {
        entries.map((entry) => (
          <KnowledgeCard
            href={getEntryHref(entry)}
            kind={getCollectionLabel(entry.collection)}
            title={entry.data.title}
            summary={entry.data.summary}
            updated={entry.data.updated}
            status={entry.data.status}
            topics={entry.data.topics}
          />
        ))
      }
    </div>
  </section>
</SiteLayout>
