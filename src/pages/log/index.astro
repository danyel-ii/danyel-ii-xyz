---
import SiteLayout from '../../layouts/SiteLayout.astro'
import KnowledgeCard from '../../components/cards/KnowledgeCard.astro'
import SectionEyebrow from '../../components/ui/SectionEyebrow.astro'
import { siteMeta } from '../../data/site'
import {
  getCollectionLabel,
  getEntryHref,
  sortByCreatedDesc,
  getVisibleCollection,
} from '../../lib/content'

const entries = sortByCreatedDesc(await getVisibleCollection('logs'))
---

<SiteLayout title={`Log | ${siteMeta.domain}`} description="Chronological learning logs from danyel-ii.xyz." canonical="/log/">
  <section class="section-shell content-index">
    <div class="section-shell__intro" data-reveal>
      <SectionEyebrow label="LOG.RUN // LEARNING JOURNAL" />
      <div class="section-shell__heading">
        <h1>Dated entries optimized for quick capture.</h1>
        <p>The log is the fastest writing surface on the site. Newest entries stay first and the required structure stays intentionally small.</p>
      </div>
    </div>
    <div class="knowledge-grid">
      {
        entries.map((entry) => (
          <KnowledgeCard
            href={getEntryHref(entry)}
            kind={getCollectionLabel(entry.collection)}
            title={entry.data.title}
            summary={entry.data.summary}
            updated={entry.data.created}
            status={entry.data.status}
            topics={entry.data.topics}
          />
        ))
      }
    </div>
  </section>
</SiteLayout>
