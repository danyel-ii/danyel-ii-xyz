---
import { siteMeta } from '../../data/site'
---

<header class="site-head">
  <div class="site-head__brand">
    <a href="/">{siteMeta.domain}</a>
  </div>

  <div class="site-head__console" aria-hidden="true">
    <div class="site-head__console-inner">
      <span>SYS.CONSOLE // PUBLIC NODE</span>
      <span>OPEN FOR STUDY GROUPS AND RESEARCH DIALOGUE</span>
    </div>
  </div>

  <nav class="site-head__nav" aria-label="Primary">
    <a href="/projects/">Projects</a>
    <a href="/notes/">Notes</a>
    <a href="/log/">Log</a>
    <a href="/topics/">Topics</a>
    <a href="/research/">Research</a>
    <a href="/search/">Search</a>
  </nav>

  <div class="site-head__utilities">
    <button class="site-head__theme js-banner-toggle" type="button" aria-label="Toggle construction banners">
      Banners
    </button>
    <button class="site-head__theme js-contrast-toggle" type="button" aria-label="Toggle contrast">
      Contrast
    </button>
    <a class="site-head__search" href="/search/" aria-label="Open search">
      Search
    </a>
    <span class="status-pill status-pill--accent">{siteMeta.status}</span>
    <span class="site-head__domain">{siteMeta.domain}</span>
  </div>

  <a
    class="site-head__qr"
    href="https://danyel-ii.xyz"
    target="_blank"
    rel="noreferrer"
    aria-label="Open danyel-ii.xyz"
  >
    <img src="/images/danyel-ii-qr.svg" alt="QR code linking to danyel-ii.xyz" width="72" height="72" />
  </a>
</header>

<script>
  const initBannerToggle = () => {
    const button = document.querySelector('.js-banner-toggle')
    if (!(button instanceof HTMLButtonElement) || button.dataset.ready === 'true') return

    const root = document.documentElement
    const storageKey = 'danyel-ii-banners'

    const applyState = (state) => {
      root.classList.toggle('construction-hidden', state === 'hidden')
    }

    applyState(localStorage.getItem(storageKey) ?? 'visible')
    button.dataset.ready = 'true'

    button.addEventListener('click', () => {
      const next = root.classList.contains('construction-hidden') ? 'visible' : 'hidden'
      applyState(next)
      localStorage.setItem(storageKey, next)
    })
  }

  const initContrastToggle = () => {
    const button = document.querySelector('.js-contrast-toggle')
    if (!(button instanceof HTMLButtonElement) || button.dataset.ready === 'true') return

    const root = document.documentElement
    const storageKey = 'danyel-ii-contrast'

    const applyMode = (mode) => {
      root.classList.toggle('theme-light', mode === 'light')
    }

    applyMode(localStorage.getItem(storageKey) ?? 'dark')
    button.dataset.ready = 'true'

    button.addEventListener('click', () => {
      const next = root.classList.contains('theme-light') ? 'dark' : 'light'
      applyMode(next)
      localStorage.setItem(storageKey, next)
    })
  }

  const initSearchShortcut = () => {
    if (document.documentElement.dataset.searchReady === 'true') return

    document.documentElement.dataset.searchReady = 'true'
    document.addEventListener('keydown', (event) => {
      const target = event.target
      if (
        target instanceof HTMLInputElement ||
        target instanceof HTMLTextAreaElement ||
        target instanceof HTMLSelectElement ||
        (target instanceof HTMLElement && target.isContentEditable)
      ) {
        return
      }

      if ((event.key === 'k' && (event.metaKey || event.ctrlKey)) || event.key === '/') {
        event.preventDefault()
        window.location.href = '/search/'
      }
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initBannerToggle()
      initContrastToggle()
      initSearchShortcut()
    }, { once: true })
  } else {
    initBannerToggle()
    initContrastToggle()
    initSearchShortcut()
  }
</script>
