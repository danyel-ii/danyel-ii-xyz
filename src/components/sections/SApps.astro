---
import AppCard from '../cards/AppCard.astro'
import SectionEyebrow from '../ui/SectionEyebrow.astro'
import { apps } from '../../data/apps'

const featured = apps.filter((item) => item.featured)
const rest = apps.filter((item) => !item.featured)
const sceneApps = apps.slice(0, 4)
---

<section id="apps" class="section-shell apps-section">
  <div class="apps-section__layout">
    <div class="section-shell__intro apps-section__intro" data-reveal>
      <SectionEyebrow label="DIR.EXE // APPLICATIONS" />
      <div class="section-shell__heading">
        <h2>Tools, small systems, and experiments that support the learning path.</h2>
        <p>
          These entries are kept descriptive and narrow in scope. The goal is to show what each item does, what it is testing, and where it is incomplete.
        </p>
      </div>
    </div>

    <div class="apps-section__content">
      <div class="apps-scene js-apps-scene" data-reveal>
        <div class="apps-scene__sticky">
          <div class="apps-scene__wall" aria-hidden="true">
            {Array.from({ length: 4 }).map(() => (
              <div class="apps-scene__row">
                {Array.from({ length: 5 }).map(() => <span>APPS</span>)}
              </div>
            ))}
          </div>

          <div class="apps-scene__cards">
            {
              sceneApps.map((item, index) => (
                <article class:list={['apps-scene__card', `apps-scene__card--${index + 1}`, 'js-apps-scene-card']}>
                  <div class="apps-scene__card-frame">
                    <div class="apps-scene__card-top">
                      <span>{item.kind}</span>
                      <span>{item.status}</span>
                    </div>
                    <div class="apps-scene__card-screen">
                      <div class="apps-scene__card-screen-inner">
                        <h3>{item.title}</h3>
                        <p>{item.excerpt}</p>
                      </div>
                    </div>
                    <div class="apps-scene__card-bottom">
                      <span>{item.tags.slice(0, 2).join(' // ')}</span>
                      <span>#{String(index + 1).padStart(3, '0')}</span>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>

      <div class="apps-section__featured">
        {featured.map((item) => <AppCard item={item} featured={true} />)}
      </div>

      <div class="apps-section__grid">
        {rest.map((item) => <AppCard item={item} />)}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  const initAppsScene = () => {
    const scene = document.querySelector('.js-apps-scene')
    if (!(scene instanceof HTMLElement) || scene.dataset.ready === 'true') return
    scene.dataset.ready = 'true'

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const cards = Array.from(scene.querySelectorAll('.js-apps-scene-card'))
    const wallRows = Array.from(scene.querySelectorAll('.apps-scene__row'))

    if (reduced || window.innerWidth < 901) {
      cards.forEach((card, index) => {
        card.style.transform = `translate3d(0, ${index * 8}px, 0)`
      })
      return
    }

    gsap.set(cards[0], { xPercent: -58, yPercent: -30, rotation: -5, scale: 0.92 })
    gsap.set(cards[1], { xPercent: 46, yPercent: -18, rotation: 4, scale: 0.95 })
    gsap.set(cards[2], { xPercent: -38, yPercent: 26, rotation: -3, scale: 0.98 })
    gsap.set(cards[3], { xPercent: 56, yPercent: 34, rotation: 5, scale: 0.88 })

    const timeline = gsap.timeline({
      scrollTrigger: {
        trigger: scene,
        start: 'top top+=92',
        end: '+=2200',
        scrub: 1,
        pin: true,
      },
    })

    timeline
      .fromTo(wallRows, { xPercent: 0 }, { xPercent: -8, stagger: 0.08, ease: 'none' }, 0)
      .to(cards[0], { xPercent: -8, yPercent: -8, rotation: -1, scale: 1.04, ease: 'power2.inOut' }, 0.04)
      .to(cards[1], { xPercent: 8, yPercent: -2, rotation: 1, scale: 1.08, ease: 'power2.inOut' }, 0.18)
      .to(cards[2], { xPercent: -16, yPercent: 12, rotation: 0, scale: 1.02, ease: 'power2.inOut' }, 0.34)
      .to(cards[3], { xPercent: 22, yPercent: 18, rotation: 2, scale: 1.02, ease: 'power2.inOut' }, 0.5)
      .to(cards[0], { xPercent: -66, yPercent: -34, rotation: -7, scale: 0.8, ease: 'power2.inOut' }, 0.7)
      .to(cards[1], { xPercent: 60, yPercent: -28, rotation: 6, scale: 0.82, ease: 'power2.inOut' }, 0.74)
      .to(cards[2], { xPercent: -58, yPercent: 42, rotation: -4, scale: 0.84, ease: 'power2.inOut' }, 0.78)
      .to(cards[3], { xPercent: 64, yPercent: 44, rotation: 7, scale: 0.8, ease: 'power2.inOut' }, 0.82)
      .to(wallRows, { xPercent: -16, stagger: 0.08, ease: 'none' }, 0.66)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAppsScene, { once: true })
  } else {
    initAppsScene()
  }
</script>
