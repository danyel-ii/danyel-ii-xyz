---
const { status } = Astro.props

const normalized = String(status).toUpperCase()

const tone =
  normalized === 'ACTIVE' || normalized === 'LIVE' || normalized === 'STABLE'
    ? 'accent'
    : normalized === 'WIP' || normalized === 'SEED'
      ? 'warning'
      : 'research'
---

<span class:list={['status-pill', `status-pill--${tone}`]}>{normalized}</span>
